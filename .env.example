# Local Development (Docker PostgreSQL)
# Use this for development with the local Docker container
DATABASE_URL=postgresql://devroast:devroast_dev_password@localhost:5432/devroast_db

# Production (Supabase PostgreSQL)
# Replace DATABASE_URL with your Supabase connection string for production:
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require

# Supabase Public API Keys (Frontend - used for read-only operations)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[ANON_KEY_FROM_SUPABASE_DASHBOARD]

# Google Gemini API
GEMINI_API_KEY=[YOUR_GEMINI_API_KEY]

# Application
NODE_ENV=development
