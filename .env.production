# Database Configuration (to be set via CI/CD or secrets)
DB_USER=devroast_prod
DB_PASSWORD=${SECRET_DB_PASSWORD}
DB_NAME=devroast_db_prod
DB_HOST=${SECRET_DB_HOST}
DB_PORT=5432

# Database URL
DATABASE_URL=postgresql://devroast_prod:${SECRET_DB_PASSWORD}@${SECRET_DB_HOST}:5432/devroast_db_prod

# Application
NODE_ENV=production
